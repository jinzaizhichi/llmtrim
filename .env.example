# Copy to .env and fill in. .env is gitignored; never commit real keys.

# Provider keys — needed by `llmtrim send` and `llmtrim serve`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override the upstream endpoint (e.g. a gateway). Defaults to the real API.
# OPENAI_BASE_URL=https://api.openai.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Live A/B benchmarking (`llmtrim bench`, built with --features live).
OPENROUTER_API_KEY=

# Optional: prune the savings ledger to the last N days (on top of the 100k-event cap).
# Unset or 0 = keep the most recent 100k events only.
# LLMTRIM_RETENTION_DAYS=90
